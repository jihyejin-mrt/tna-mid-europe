{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp@0.1.4"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "redash": {
      "command": "npx",
      "args": ["-y", "redash-mcp@3.0.4"],
      "env": {
        "REDASH_URL": "${REDASH_URL:-https://redash.myrealtrip.net}",
        "REDASH_API_KEY": "${REDASH_API_KEY}"
      }
    }
  }
}
